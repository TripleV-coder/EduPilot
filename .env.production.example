# EduPilot AI Configuration - Production
# This file contains all AI settings for production deployment

# AI Model Settings
AI_MODEL_PATH=/app/models
AI_CACHE_DIR=/app/.ai-cache
AI_MAX_MEMORY_PERCENT=80

# Application Settings
NODE_ENV=production
PORT=3000

# Database (already configured in .env)
DATABASE_URL="postgresql://..."

# Redis (optional - for caching)
REDIS_URL="redis://localhost:6379"

# AI Performance Settings
AI_MAX_CONCURRENT_REQUESTS=10
AI_REQUEST_TIMEOUT=60000
AI_STREAMING_ENABLED=true

# Logging
LOG_LEVEL=info
AI_LOG_LEVEL=info

# Security
AI_ENABLE_RATE_LIMITING=true
AI_MAX_REQUESTS_PER_MINUTE=50
