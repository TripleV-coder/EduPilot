generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SubscriptionPlan {
  id           String   @id @default(cuid())
  name         String   @unique
  code         String   @unique
  description  String?
  maxStudents  Int      @default(100)
  maxTeachers  Int      @default(10)
  maxStorageGB Int      @default(5)
  features     String[] @default([])
  priceMonthly Decimal  @db.Decimal(10, 2)
  priceYearly  Decimal  @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  schools      School[]

  @@map("subscription_plans")
}

model School {
  id                    String                @id @default(cuid())
  name                  String
  code                  String                @unique
  type                  SchoolType            @default(PRIVATE)
  level                 SchoolLevel
  address               String?
  city                  String?
  phone                 String?
  email                 String?
  logo                  String?
  isActive              Boolean               @default(true)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  planId                String?
  parentSchoolId        String?
  subscriptionStatus    SubscriptionStatus?   @default(TRIAL)
  academicConfig        AcademicConfig?
  academicYears         AcademicYear[]
  announcements         Announcement[]
  auditLogs             AuditLog[]
  books                 Book[]
  canteenMenus          CanteenMenu[]
  classLevels           ClassLevel[]
  classes               Class[]
  configOptions         ConfigOption[]
  dataRetentionPolicies DataRetentionPolicy[]
  evaluationTypes       EvaluationType[]
  fees                  Fee[]
  importTemplates       ImportTemplate[]
  leaderboard           Leaderboard[]
  mealTickets           MealTicket[]
  publicHolidays        PublicHoliday[]
  resources             Resource[]
  schoolCalendarEvents  SchoolCalendarEvent[]
  schoolEvents          SchoolEvent[]
  schoolHolidays        SchoolHoliday[]
  parentSchool          School?               @relation("SchoolHierarchy", fields: [parentSchoolId], references: [id])
  childSchools          School[]              @relation("SchoolHierarchy")
  plan                  SubscriptionPlan?     @relation(fields: [planId], references: [id])
  studentProfiles       StudentProfile[]
  subjectCategories     SubjectCategory[]
  subjects              Subject[]
  teacherProfiles       TeacherProfile[]
  users                 User[]

  @@map("schools")
}

model AcademicConfig {
  id           String     @id @default(cuid())
  schoolId     String     @unique
  periodType   PeriodType @default(TRIMESTER)
  periodsCount Int        @default(3)
  maxGrade     Decimal    @default(20) @db.Decimal(5, 2)
  passingGrade Decimal    @default(10) @db.Decimal(5, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  school       School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("academic_configs")
}

model AcademicYear {
  id                   String                @id @default(cuid())
  schoolId             String
  name                 String
  startDate            DateTime
  endDate              DateTime
  isCurrent            Boolean               @default(false)
  status               AcademicYearStatus    @default(ACTIVE)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  school               School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  certificates         Certificate[]
  enrollments          Enrollment[]
  fees                 Fee[]
  gradeHistory         GradeHistory[]
  periods              Period[]
  schoolCalendarEvents SchoolCalendarEvent[]
  schoolHolidays       SchoolHoliday[]
  studentAnalytics     StudentAnalytics[]
  studentOrientations  StudentOrientation[]

  @@unique([schoolId, name])
  @@map("academic_years")
}

model Period {
  id               String             @id @default(cuid())
  academicYearId   String
  name             String
  type             PeriodType
  startDate        DateTime
  endDate          DateTime
  sequence         Int
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  evaluations      Evaluation[]
  gradeHistory     GradeHistory[]
  academicYear     AcademicYear       @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  studentAnalytics StudentAnalytics[]

  @@unique([academicYearId, sequence])
  @@map("periods")
}

model User {
  id                        String                      @id @default(cuid())
  email                     String                      @unique
  emailVerified             DateTime?
  password                  String
  firstName                 String
  lastName                  String
  phone                     String?
  avatar                    String?
  role                      UserRole
  roles                     UserRole[]                  // Hybrid roles support
  isActive                  Boolean                     @default(true)
  schoolId                  String?
  failedLoginAttempts       Int                         @default(0)
  lockedUntil               DateTime?
  passwordChangedAt         DateTime?
  mustChangePassword        Boolean                     @default(false)
  roleChangedAt             DateTime?
  isTwoFactorEnabled        Boolean                     @default(false)
  twoFactorSecret           String?
  twoFactorBackupCodes      String[]                    @default([])
  preferences               Json?                       @default("{}")
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  accounts                  Account[]
  announcementsAuthored     Announcement[]
  appointmentsCreated       Appointment[]               @relation("AppointmentCreator")
  attendancesRecorded       Attendance[]                @relation("RecordedBy")
  auditLogs                 AuditLog[]
  behaviorIncidentsReported BehaviorIncident[]
  certificatesIssued        Certificate[]
  coursesCreated            Course[]
  dataAccessProcessed       DataAccessRequest[]         @relation("Processor")
  dataAccessRequests        DataAccessRequest[]         @relation("Requester")
  dataConsents              DataConsent[]
  examTemplatesCreated      ExamTemplate[]
  firstLoginTokens          FirstLoginToken[]
  homeworksGraded           HomeworkSubmission[]        @relation("GradedBy")
  homeworksCreated          Homework[]
  importTemplatesCreated    ImportTemplate[]
  leaderboard               Leaderboard[]
  mealTickets               MealTicket[]
  messagesReceived          Message[]                   @relation("Recipient")
  messagesSent              Message[]                   @relation("Sender")
  notifications             Notification[]
  orientationRecsValidated  OrientationRecommendation[]
  parentProfile             ParentProfile?
  paymentsReceived          Payment[]                   @relation("PaymentReceivedBy")
  paymentsReconciled        Payment[]                   @relation("PaymentReconciledBy")
  resourcesUploaded         Resource[]
  sanctionsAssigned         Sanction[]
  schoolEventsCreated       SchoolEvent[]
  sessions                  Session[]
  studentProfile            StudentProfile?
  teacherProfile            TeacherProfile?
  userAchievements          UserAchievement[]
  school                    School?                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([firstName])
  @@index([lastName])
  @@index([schoolId])
  @@index([role])
  @@index([isActive])
  @@index([createdAt])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

model FirstLoginToken {
  id           String    @id @default(cuid())
  userId       String
  token        String    @unique
  tempPassword String?
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("first_login_tokens")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String
  isSecret  Boolean  @default(false)
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([key])
  @@map("system_settings")
}

model TeacherProfile {
  id             String                @id @default(cuid())
  userId         String                @unique
  matricule      String?
  schoolId       String
  specialization String?
  hireDate       DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  deletedAt      DateTime?
  appointments   Appointment[]
  classSubjects  ClassSubject[]
  mainClasses    Class[]
  availabilities TeacherAvailability[]
  school         School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([schoolId, matricule])
  @@index([schoolId])
  @@map("teacher_profiles")
}

model StudentProfile {
  id                  String               @id @default(cuid())
  userId              String               @unique
  matricule           String
  schoolId            String
  dateOfBirth         DateTime?
  gender              Gender?
  birthPlace          String?
  nationality         String?
  address             String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  appointments        Appointment[]
  attendances         Attendance[]
  behaviorIncidents   BehaviorIncident[]
  borrowings          BorrowingRecord[]
  certificates        Certificate[]
  courseEnrollments   CourseEnrollment[]
  enrollments         Enrollment[]
  eventParticipations EventParticipation[]
  examSessions        ExamSession[]
  gradeHistory        GradeHistory[]
  grades              Grade[]
  homeworkSubmissions HomeworkSubmission[]
  lessonCompletions   LessonCompletion[]
  medicalRecord       MedicalRecord?
  parentStudents      ParentStudent[]
  paymentPlans        PaymentPlan[]
  payments            Payment[]
  scholarships        Scholarship[]
  studentAnalytics    StudentAnalytics[]
  studentOrientations StudentOrientation[]
  school              School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([schoolId, matricule])
  @@index([schoolId])
  @@index([matricule])
  @@map("student_profiles")
}

model ParentProfile {
  id             String          @id @default(cuid())
  userId         String          @unique
  profession     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  appointments   Appointment[]
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentStudents ParentStudent[]

  @@map("parent_profiles")
}

model ParentStudent {
  id           String         @id @default(cuid())
  parentId     String
  studentId    String
  relationship String
  isPrimary    Boolean        @default(false)
  createdAt    DateTime       @default(now())
  parent       ParentProfile  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@map("parent_students")
}

model ClassLevel {
  id                  String               @id @default(cuid())
  schoolId            String
  name                String
  code                String
  level               SchoolLevel
  sequence            Int
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  school              School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classes             Class[]
  resources           Resource[]
  studentOrientations StudentOrientation[]

  @@unique([schoolId, code])
  @@map("class_levels")
}

model Class {
  id            String          @id @default(cuid())
  schoolId      String
  classLevelId  String
  name          String
  capacity      Int?
  mainTeacherId String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  attendances   Attendance[]
  classSubjects ClassSubject[]
  classLevel    ClassLevel      @relation(fields: [classLevelId], references: [id], onDelete: Cascade)
  mainTeacher   TeacherProfile? @relation(fields: [mainTeacherId], references: [id])
  school        School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  enrollments   Enrollment[]
  schedules     Schedule[]

  @@unique([schoolId, classLevelId, name])
  @@map("classes")
}

model Subject {
  id                  String               @id @default(cuid())
  schoolId            String
  name                String
  code                String
  category            String?
  coefficient         Decimal              @default(1) @db.Decimal(5, 2)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  classSubjects       ClassSubject[]
  gradeHistory        GradeHistory[]
  resources           Resource[]
  subjectPerformances SubjectPerformance[]
  school              School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, code])
  @@map("subjects")
}

model ClassSubject {
  id            String          @id @default(cuid())
  classId       String
  subjectId     String
  teacherId     String?
  coefficient   Decimal         @default(1) @db.Decimal(5, 2)
  weeklyHours   Decimal?        @db.Decimal(4, 2)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  class         Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject       Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher       TeacherProfile? @relation(fields: [teacherId], references: [id])
  courses       Course[]
  evaluations   Evaluation[]
  examTemplates ExamTemplate[]
  homeworks     Homework[]
  schedules     Schedule[]

  @@unique([classId, subjectId])
  @@map("class_subjects")
}

model Enrollment {
  id             String           @id @default(cuid())
  studentId      String
  classId        String
  academicYearId String
  status         EnrollmentStatus @default(ACTIVE)
  enrolledAt     DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  class          Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  student        StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYearId])
  @@map("enrollments")
}

model EvaluationType {
  id          String       @id @default(cuid())
  schoolId    String
  name        String
  code        String
  weight      Decimal      @default(1) @db.Decimal(5, 2)
  maxCount    Int?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  evaluations Evaluation[]

  @@unique([schoolId, code])
  @@map("evaluation_types")
}

model Evaluation {
  id             String         @id @default(cuid())
  classSubjectId String
  periodId       String
  typeId         String
  title          String?
  date           DateTime
  maxGrade       Decimal        @default(20) @db.Decimal(5, 2)
  coefficient    Decimal        @default(1) @db.Decimal(5, 2)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  classSubject   ClassSubject   @relation(fields: [classSubjectId], references: [id], onDelete: Cascade)
  period         Period         @relation(fields: [periodId], references: [id], onDelete: Cascade)
  type           EvaluationType @relation(fields: [typeId], references: [id], onDelete: Cascade)
  grades         Grade[]

  @@index([classSubjectId])
  @@index([periodId])
  @@index([typeId])
  @@index([date])
  @@index([createdAt])
  @@map("evaluations")
}

model Grade {
  id           String         @id @default(cuid())
  evaluationId String
  studentId    String
  value        Decimal?       @db.Decimal(5, 2)
  isAbsent     Boolean        @default(false)
  isExcused    Boolean        @default(false)
  comment      String?
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  evaluation   Evaluation     @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, studentId])
  @@index([evaluationId])
  @@index([studentId, evaluationId])
  @@map("grades")
}

model Schedule {
  id             String        @id @default(cuid())
  classId        String
  classSubjectId String?
  dayOfWeek      Int           @db.SmallInt
  startTime      String
  endTime        String
  room           String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  class          Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  classSubject   ClassSubject? @relation(fields: [classSubjectId], references: [id])

  @@index([classId, dayOfWeek])
  @@index([classSubjectId])
  @@map("schedules")
}

model Fee {
  id             String        @id @default(cuid())
  schoolId       String
  academicYearId String?
  name           String
  description    String?
  amount         Decimal       @db.Decimal(10, 2)
  classLevelCode String?
  dueDate        DateTime?
  isRequired     Boolean       @default(true)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  paymentPlans   PaymentPlan[]
  payments       Payment[]

  @@index([schoolId])
  @@map("fees")
}

model Payment {
  id               String         @id @default(cuid())
  studentId        String
  feeId            String
  amount           Decimal        @db.Decimal(10, 2)
  method           PaymentMethod
  reference        String?        @unique
  paidAt           DateTime?
  receivedBy       String?
  notes            String?
  status           PaymentStatus  @default(PENDING)
  reconciledAt     DateTime?
  reconciledBy     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  mealTickets      MealTicket[]
  fee              Fee            @relation(fields: [feeId], references: [id], onDelete: Cascade)
  receivedByUser   User?          @relation("PaymentReceivedBy", fields: [receivedBy], references: [id])
  reconciledByUser User?          @relation("PaymentReconciledBy", fields: [reconciledBy], references: [id])
  student          StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, feeId])
  @@index([reference])
  @@index([status])
  @@map("payments")
}

model PaymentPlan {
  id                  String               @id @default(cuid())
  studentId           String
  feeId               String
  totalAmount         Decimal              @db.Decimal(10, 2)
  installments        Int                  @default(1)
  paidAmount          Decimal              @default(0) @db.Decimal(10, 2)
  status              PaymentPlanStatus    @default(ACTIVE)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  installmentPayments InstallmentPayment[]
  fee                 Fee                  @relation(fields: [feeId], references: [id], onDelete: Cascade)
  student             StudentProfile       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([feeId])
  @@map("payment_plans")
}

model InstallmentPayment {
  id            String            @id @default(cuid())
  paymentPlanId String
  amount        Decimal           @db.Decimal(10, 2)
  dueDate       DateTime
  paidAt        DateTime?
  status        InstallmentStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  paymentPlan   PaymentPlan       @relation(fields: [paymentPlanId], references: [id], onDelete: Cascade)

  @@index([paymentPlanId])
  @@index([dueDate])
  @@map("installment_payments")
}

model Scholarship {
  id         String          @id @default(cuid())
  studentId  String
  name       String
  type       ScholarshipType
  amount     Decimal         @db.Decimal(10, 2)
  percentage Int?
  startDate  DateTime
  endDate    DateTime?
  isActive   Boolean         @default(true)
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  student    StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("scholarships")
}

model Attendance {
  id                    String           @id @default(cuid())
  studentId             String
  classId               String
  date                  DateTime
  status                AttendanceStatus
  reason                String?
  justificationDocument String?
  recordedById          String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  class                 Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  recordedBy            User?            @relation("RecordedBy", fields: [recordedById], references: [id])
  student               StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, classId, date])
  @@index([studentId, date])
  @@index([classId, date])
  @@index([status])
  @@map("attendances")
}

model Homework {
  id             String               @id @default(cuid())
  classSubjectId String
  title          String
  description    String
  dueDate        DateTime
  maxGrade       Decimal?             @default(20) @db.Decimal(5, 2)
  coefficient    Decimal              @default(1) @db.Decimal(5, 2)
  attachments    String[]             @default([])
  isPublished    Boolean              @default(true)
  createdById    String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deletedAt      DateTime?
  submissions    HomeworkSubmission[]
  classSubject   ClassSubject         @relation(fields: [classSubjectId], references: [id], onDelete: Cascade)
  createdBy      User?                @relation(fields: [createdById], references: [id])

  @@index([classSubjectId, dueDate])
  @@index([dueDate])
  @@map("homeworks")
}

model HomeworkSubmission {
  id          String         @id @default(cuid())
  homeworkId  String
  studentId   String
  content     String?
  attachments String[]       @default([])
  submittedAt DateTime       @default(now())
  grade       Decimal?       @db.Decimal(5, 2)
  feedback    String?
  gradedAt    DateTime?
  gradedById  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  gradedBy    User?          @relation("GradedBy", fields: [gradedById], references: [id])
  homework    Homework       @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([homeworkId, studentId])
  @@index([studentId, submittedAt])
  @@index([homeworkId])
  @@map("homework_submissions")
}

model Message {
  id                 String    @id @default(cuid())
  senderId           String
  recipientId        String
  subject            String
  content            String
  parentId           String?
  isRead             Boolean   @default(false)
  readAt             DateTime?
  isArchived         Boolean   @default(false)
  deletedBySender    Boolean   @default(false)
  deletedByRecipient Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?
  parent             Message?  @relation("MessageThread", fields: [parentId], references: [id])
  replies            Message[] @relation("MessageThread")
  recipient          User      @relation("Recipient", fields: [recipientId], references: [id], onDelete: Cascade)
  sender             User      @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId, deletedBySender])
  @@index([recipientId, deletedByRecipient, isRead])
  @@index([createdAt])
  @@map("messages")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  schoolId  String?
  action    String
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  school    School?  @relation(fields: [schoolId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([schoolId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Resource {
  id           String       @id @default(cuid())
  schoolId     String
  title        String
  description  String?
  type         ResourceType
  category     String?
  subjectId    String?
  classLevelId String?
  fileUrl      String
  fileType     String
  fileSize     Int?
  thumbnailUrl String?
