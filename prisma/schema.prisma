// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// MULTI-TENANT - ETABLISSEMENTS
// ============================================

model School {
  id        String      @id @default(cuid())
  name      String
  code      String      @unique
  type      SchoolType  @default(PRIVATE)
  level     SchoolLevel
  address   String?
  city      String?
  phone     String?
  email     String?
  logo      String?
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Relations
  users                 User[]
  academicConfigs       AcademicConfig[]
  academicYears         AcademicYear[]
  classes               Class[]
  subjects              Subject[]
  evaluationTypes       EvaluationType[]
  fees                  Fee[]
  classLevels           ClassLevel[]
  announcements         Announcement[]
  resources             Resource[]
  dataRetentionPolicies DataRetentionPolicy[]
  schoolEvents          SchoolEvent[]
  schoolHolidays        SchoolHoliday[]
  publicHolidays        PublicHoliday[]
  calendarEvents        SchoolCalendarEvent[]
  subjectCategories     SubjectCategory[]
  configOptions         ConfigOption[]
  importTemplates       ImportTemplate[]
  teacherAssignments    TeacherSchoolAssignment[]
  communicationTemplates CommunicationTemplate[]
  communicationLogs      CommunicationLog[]
  leaderboardEntries     Leaderboard[]
  canteenMenus           CanteenMenu[]
  mealTickets            MealTicket[]
  books                  Book[]

  @@map("schools")
}

enum SchoolType {
  PUBLIC
  PRIVATE
  RELIGIOUS
  INTERNATIONAL
}

enum SchoolLevel {
  PRIMARY
  SECONDARY_COLLEGE
  SECONDARY_LYCEE
  MIXED
}

// ============================================
// CONFIGURATION ACADEMIQUE
// ============================================

model AcademicConfig {
  id           String     @id @default(cuid())
  schoolId     String
  periodType   PeriodType @default(TRIMESTER)
  periodsCount Int        @default(3)
  maxGrade     Decimal    @default(20) @db.Decimal(5, 2)
  passingGrade Decimal    @default(10) @db.Decimal(5, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId])
  @@map("academic_configs")
}

enum PeriodType {
  TRIMESTER
  SEMESTER
  HYBRID
}

// ============================================
// ANNEE SCOLAIRE & PERIODES
// ============================================

model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school              School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  periods             Period[]
  enrollments         Enrollment[]
  fees                Fee[]
  certificates        Certificate[]
  schoolHolidays      SchoolHoliday[]
  calendarEvents      SchoolCalendarEvent[]
  studentOrientations StudentOrientation[]
  studentAnalytics    StudentAnalytics[]
  gradeHistory        GradeHistory[]

  @@unique([schoolId, name])
  @@map("academic_years")
}

model Period {
  id             String     @id @default(cuid())
  academicYearId String
  name           String
  type           PeriodType
  startDate      DateTime
  endDate        DateTime
  sequence       Int
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  academicYear     AcademicYear       @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  evaluations      Evaluation[]
  studentAnalytics StudentAnalytics[]
  gradeHistory     GradeHistory[]

  @@unique([academicYearId, sequence])
  @@map("periods")
}

// ============================================
// UTILISATEURS & AUTHENTIFICATION
// ============================================

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  emailVerified        DateTime?
  password             String
  firstName            String
  lastName             String
  phone                String?
  avatar               String?
  role                 UserRole
  isActive             Boolean   @default(true)
  schoolId             String?
  passwordChangedAt    DateTime?
  
  // 2FA / MFA
  isTwoFactorEnabled   Boolean   @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes String[]  @default([])
  roleChangedAt        DateTime?
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  school                School?              @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  teacherProfile        TeacherProfile?
  studentProfile        StudentProfile?
  parentProfile         ParentProfile?
  accounts              Account[]
  sessions              Session[]
  auditLogs             AuditLog[]
  importTemplates       ImportTemplate[]
  notifications         Notification[]
  recordedAttendances   Attendance[]         @relation("RecordedAttendances")
  sentMessages          Message[]            @relation("SentMessages")
  receivedMessages      Message[]            @relation("ReceivedMessages")
  createdHomeworks      Homework[]           @relation("CreatedHomeworks")
  gradedSubmissions     HomeworkSubmission[] @relation("GradedSubmissions")
  issuedCertificates    Certificate[]        @relation("IssuedCertificates")
  authoredAnnouncements Announcement[]       @relation("AuthoredAnnouncements")
  uploadedResources     Resource[]           @relation("UploadedResources")
  dataConsents          DataConsent[]        @relation("UserConsents")
  dataAccessRequests    DataAccessRequest[]  @relation("UserDataRequests")
  processedDataRequests DataAccessRequest[]  @relation("ProcessedDataRequests")
  createdAppointments   Appointment[]        @relation("CreatedAppointments")
  reportedIncidents     BehaviorIncident[]   @relation("ReportedIncidents")
  assignedSanctions     Sanction[]           @relation("AssignedSanctions")
  createdEvents          SchoolEvent[]                @relation("CreatedEvents")
  createdExams           ExamTemplate[]               @relation("CreatedExams")
  createdCourses         Course[]                     @relation("CreatedCourses")
  validatedRecommendations OrientationRecommendation[] @relation("ValidatedRecommendations")
  firstLoginTokens         FirstLoginToken[]
  communicationPreference  CommunicationPreference?
  communicationLogs        CommunicationLog[]
  userAchievements         UserAchievement[]
  leaderboardEntries       Leaderboard[]
  mealTickets              MealTicket[]
  borrowingRecords         BorrowingRecord[]

  @@index([firstName])
  @@index([lastName])
  @@index([schoolId])
  @@index([role])
  @@index([isActive])
  @@index([createdAt])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  DIRECTOR
  TEACHER
  STUDENT
  PARENT
  ACCOUNTANT
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

model FirstLoginToken {
  id           String    @id @default(cuid())
  userId       String
  token        String    @unique
  tempPassword String?
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("first_login_tokens")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String
  isSecret  Boolean  @default(false)
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([key])
  @@map("system_settings")
}

// ============================================
// PROFILS SPECIFIQUES PAR ROLE
// ============================================

model TeacherProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  matricule      String?
  schoolId       String    // Added for multi-tenant uniqueness
  specialization String?
  hireDate       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  classSubjects        ClassSubject[]
  mainClasses          Class[]                @relation("MainTeacher")
  appointments         Appointment[]
  teacherAvailabilities TeacherAvailability[]
  assignments          TeacherSchoolAssignment[]

  @@unique([schoolId, matricule]) // Multi-tenant unique constraint (nullable allowed)
  @@index([schoolId])
  @@map("teacher_profiles")
}

model TeacherSchoolAssignment {
  id        String   @id @default(cuid())
  teacherId String
  schoolId  String
  role      String?
  startDate DateTime @default(now())
  endDate   DateTime?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  school  School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([teacherId, schoolId])
  @@index([schoolId])
  @@map("teacher_school_assignments")
}

model StudentProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  matricule   String
  schoolId    String    // Added for multi-tenant uniqueness
  dateOfBirth DateTime?
  gender      Gender?
  birthPlace  String?
  nationality String?   @default("Beninoise")
  address     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments         Enrollment[]
  grades              Grade[]
  payments            Payment[]
  parentLinks         ParentStudent[]
  attendances         Attendance[]
  homeworkSubmissions HomeworkSubmission[]
  certificates        Certificate[]
  appointments        Appointment[]
  behaviorIncidents   BehaviorIncident[]
  medicalRecord       MedicalRecord?
  eventParticipations EventParticipation[]
  examSessions        ExamSession[]
  courseEnrollments   CourseEnrollment[]
  lessonCompletions   LessonCompletion[]
  paymentPlans        PaymentPlan[]
  scholarships        Scholarship[]
  orientations        StudentOrientation[]
  analytics           StudentAnalytics[]
  gradeHistory        GradeHistory[]

  @@unique([schoolId, matricule]) // Multi-tenant unique constraint
  @@index([schoolId])
  @@index([matricule])
  @@map("student_profiles")
}

enum Gender {
  MALE
  FEMALE
}

model ParentProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  profession String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  children     ParentStudent[]
  appointments Appointment[]

  @@map("parent_profiles")
}

model ParentStudent {
  id           String   @id @default(cuid())
  parentId     String
  studentId    String
  relationship String
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  parent  ParentProfile  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@map("parent_students")
}

// ============================================
// NIVEAUX ET CLASSES
// ============================================

model ClassLevel {
  id        String      @id @default(cuid())
  schoolId  String
  name      String
  code      String
  level     SchoolLevel
  sequence  Int
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  school              School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classes             Class[]
  resources           Resource[]
  studentOrientations StudentOrientation[]

  @@unique([schoolId, code])
  @@map("class_levels")
}

model Class {
  id            String   @id @default(cuid())
  schoolId      String
  classLevelId  String
  name          String
  capacity      Int?
  mainTeacherId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school        School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classLevel    ClassLevel      @relation(fields: [classLevelId], references: [id], onDelete: Cascade)
  mainTeacher   TeacherProfile? @relation("MainTeacher", fields: [mainTeacherId], references: [id], onDelete: SetNull)
  enrollments   Enrollment[]
  classSubjects ClassSubject[]
  schedules     Schedule[]
  attendances   Attendance[]

  @@unique([schoolId, classLevelId, name])
  @@map("classes")
}

// ============================================
// MATIERES ET AFFECTATIONS
// ============================================

model Subject {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  code        String
  category    String?
  coefficient Int      @default(1) // Coefficient pour calcul moyenne (1-5)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school              School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classSubjects       ClassSubject[]
  resources           Resource[]
  subjectPerformances SubjectPerformance[]
  gradeHistory        GradeHistory[]

  @@unique([schoolId, code])
  @@map("subjects")
}

model ClassSubject {
  id          String   @id @default(cuid())
  classId     String
  subjectId   String
  teacherId   String?
  coefficient Decimal  @default(1) @db.Decimal(5, 2)
  weeklyHours Decimal? @db.Decimal(4, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  class         Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject       Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher       TeacherProfile? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  evaluations   Evaluation[]
  schedules     Schedule[]
  homeworks     Homework[]
  examTemplates ExamTemplate[]
  courses       Course[]

  @@unique([classId, subjectId])
  @@map("class_subjects")
}

// ============================================
// INSCRIPTIONS
// ============================================

model Enrollment {
  id             String           @id @default(cuid())
  studentId      String
  classId        String
  academicYearId String
  status         EnrollmentStatus @default(ACTIVE)
  enrolledAt     DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class        Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYearId])
  @@map("enrollments")
}

enum EnrollmentStatus {
  ACTIVE
  TRANSFERRED
  GRADUATED
  DROPPED
  SUSPENDED
}

// ============================================
// EVALUATIONS ET NOTES
// ============================================

model EvaluationType {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  code      String
  weight    Decimal  @default(1) @db.Decimal(5, 2)
  maxCount  Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  evaluations Evaluation[]

  @@unique([schoolId, code])
  @@map("evaluation_types")
}

model Evaluation {
  id             String   @id @default(cuid())
  classSubjectId String
  periodId       String
  typeId         String
  title          String?
  date           DateTime
  maxGrade       Decimal  @default(20) @db.Decimal(5, 2)
  coefficient    Decimal  @default(1) @db.Decimal(5, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  classSubject ClassSubject   @relation(fields: [classSubjectId], references: [id], onDelete: Cascade)
  period       Period         @relation(fields: [periodId], references: [id], onDelete: Cascade)
  type         EvaluationType @relation(fields: [typeId], references: [id], onDelete: Cascade)
  grades       Grade[]

  @@index([classSubjectId])
  @@index([periodId])
  @@index([typeId])
  @@index([date])
  @@index([createdAt])
  @@map("evaluations")
}

model Grade {
  id           String   @id @default(cuid())
  evaluationId String
  studentId    String
  value        Decimal? @db.Decimal(5, 2)
  isAbsent     Boolean  @default(false)
  isExcused    Boolean  @default(false)
  comment      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  evaluation Evaluation     @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  student    StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, studentId])
  @@index([evaluationId])
  @@index([studentId, evaluationId])
  @@map("grades")
}

// ============================================
// EMPLOI DU TEMPS
// ============================================

model Schedule {
  id             String   @id @default(cuid())
  classId        String
  classSubjectId String?
  dayOfWeek      Int      @db.SmallInt // 0-6 (Lundi-Dimanche)
  startTime      String   // Format: "HH:mm" (ex: "08:00")
  endTime        String   // Format: "HH:mm" (ex: "09:30")
  room           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  class        Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  classSubject ClassSubject? @relation(fields: [classSubjectId], references: [id], onDelete: SetNull)

  @@index([classId, dayOfWeek])
  @@index([classSubjectId])
  @@map("schedules")
}

// ============================================
// FINANCES
// ============================================

model PaymentPlan {
  id             String   @id @default(cuid())
  studentId      String
  feeId          String
  totalAmount    Decimal  @db.Decimal(10, 2)
  installments   Int      @default(1)
  paidAmount     Decimal  @default(0) @db.Decimal(10, 2)
  status         String   @default("ACTIVE") // ACTIVE, COMPLETED, DEFAULTED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fee     Fee            @relation(fields: [feeId], references: [id], onDelete: Cascade)
  installmentPayments InstallmentPayment[]

  @@index([studentId])
  @@index([feeId])
  @@map("payment_plans")
}

model InstallmentPayment {
  id            String   @id @default(cuid())
  paymentPlanId String
  amount        Decimal  @db.Decimal(10, 2)
  dueDate       DateTime
  paidAt        DateTime?
  status        String   @default("PENDING") // PENDING, PAID, OVERDUE
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  paymentPlan PaymentPlan @relation(fields: [paymentPlanId], references: [id], onDelete: Cascade)

  @@index([paymentPlanId])
  @@index([dueDate])
  @@map("installment_payments")
}

model Scholarship {
  id          String   @id @default(cuid())
  studentId   String
  name        String
  type        String   // MERIT, NEED_BASED, SPORTS, etc.
  amount      Decimal  @db.Decimal(10, 2)
  percentage  Int?     // If percentage-based
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean  @default(true)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("scholarships")
}

model Fee {
  id             String    @id @default(cuid())
  schoolId       String
  academicYearId String?
  name           String
  description    String?
  amount         Decimal   @db.Decimal(10, 2)
  classLevelCode String?
  dueDate        DateTime?
  isRequired     Boolean   @default(true)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  payments     Payment[]
  paymentPlans PaymentPlan[]

  @@map("fees")
}

model Payment {
  id            String        @id @default(cuid())
  studentId     String
  feeId         String
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod
  provider      String?       // "FLUTTERWAVE", "PAYSTACK", "FEDAPAY"
  transactionId String?       @unique // External Transaction ID
  providerData  Json?         // Store full webhook payload
  reference     String?       // Internal reference
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?
  reconciledAt  DateTime?
  reconciledBy  String?
  receivedBy    String?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fee     Fee            @relation(fields: [feeId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@map("payments")
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY_MTN
  MOBILE_MONEY_MOOV
  BANK_TRANSFER
  CHECK
  OTHER
}

enum PaymentStatus {
  PENDING
  VERIFIED
  RECONCILED
  CANCELLED
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  GRADE
  PAYMENT
  BULLETIN
  ENROLLMENT
  SYSTEM
  MESSAGE
  ATTENDANCE
}

// ============================================
// PRESENCES / ABSENCES
// ============================================

model Attendance {
  id                     String           @id @default(cuid())
  studentId              String
  classId                String
  date                   DateTime
  status                 AttendanceStatus
  reason                 String?
  justificationDocument  String?
  recordedById           String
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  student    StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class      Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  recordedBy User           @relation("RecordedAttendances", fields: [recordedById], references: [id])

  @@unique([studentId, classId, date])
  @@index([studentId, date])
  @@index([classId, date])
  @@index([status])
  @@map("attendances")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

// ============================================
// DEVOIRS & TRAVAUX
// ============================================

model Homework {
  id             String         @id @default(cuid())
  classSubjectId String
  title          String
  description    String         @db.Text
  dueDate        DateTime
  maxGrade       Decimal?       @default(20) @db.Decimal(5, 2)
  coefficient    Decimal        @default(1) @db.Decimal(5, 2)
  attachments    String[]       @default([])
  isPublished    Boolean        @default(true)
  createdById    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  classSubject ClassSubject         @relation(fields: [classSubjectId], references: [id], onDelete: Cascade)
  createdBy    User                 @relation("CreatedHomeworks", fields: [createdById], references: [id])
  submissions  HomeworkSubmission[]

  @@index([classSubjectId, dueDate])
  @@index([dueDate])
  @@map("homeworks")
}

model HomeworkSubmission {
  id           String    @id @default(cuid())
  homeworkId   String
  studentId    String
  content      String?   @db.Text
  attachments  String[]  @default([])
  submittedAt  DateTime  @default(now())
  grade        Decimal?  @db.Decimal(5, 2)
  feedback     String?   @db.Text
  gradedAt     DateTime?
  gradedById   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  homework  Homework        @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  student   StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  gradedBy  User?           @relation("GradedSubmissions", fields: [gradedById], references: [id])

