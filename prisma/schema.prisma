model StudentOrientation {
  id             String            @id @default(cuid())
  studentId      String
  academicYearId String
  classLevelId   String            // Niveau actuel (ex: 3ème pour orientation post-BEPC)
  status         OrientationStatus @default(PENDING)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  student           StudentProfile              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear      AcademicYear                @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  classLevel        ClassLevel                  @relation(fields: [classLevelId], references: [id], onDelete: Cascade)
  recommendations   OrientationRecommendation[]
  subjectAnalyses   SubjectGroupAnalysis[]

  @@unique([studentId, academicYearId])
  @@index([studentId])
  @@index([academicYearId])
  @@map("student_orientations")
}

enum OrientationStatus {
  PENDING           // En attente d'analyse
  ANALYZED          // Analysé
  RECOMMENDED       // Recommandation émise
  VALIDATED         // Validé par le conseil
  ACCEPTED          // Accepté par l'élève/parents
  REJECTED          // Rejeté
}

model OrientationRecommendation {
  id                  String              @id @default(cuid())
  orientationId       String
  recommendedSeries   RecommendedSeries
  rank                Int                 @default(1) // 1 = premier choix
  score               Decimal             @db.Decimal(5, 2) // Score de compatibilité (0-100)
  justification       String              @db.Text
  strengths           String[]            @default([]) // Points forts pour cette série
  warnings            String[]            @default([]) // Points d'attention
  isValidated         Boolean             @default(false)
  validatedById       String?
  validatedAt         DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  orientation StudentOrientation @relation(fields: [orientationId], references: [id], onDelete: Cascade)
  validatedBy User?              @relation("ValidatedRecommendations", fields: [validatedById], references: [id])

  @@index([orientationId])
  @@map("orientation_recommendations")
}

enum RecommendedSeries {
  // Séries générales
  SERIE_A           // Littéraire
  SERIE_B           // Économique et Social
  SERIE_C           // Mathématiques et Sciences Physiques
  SERIE_D           // Sciences de la Vie et de la Terre

  // Séries techniques
  SERIE_E           // Mathématiques et Technique
  SERIE_F1          // Fabrication Mécanique
  SERIE_F2          // Électronique
  SERIE_F3          // Électrotechnique
  SERIE_F4          // Génie Civil
  SERIE_G1          // Techniques Administratives
  SERIE_G2          // Techniques Quantitatives de Gestion
  SERIE_G3          // Techniques Commerciales

  // Formations professionnelles
  FORMATION_PRO     // Formation professionnelle
  APPRENTISSAGE     // Apprentissage
}

model SubjectGroupAnalysis {
  id              String        @id @default(cuid())
  orientationId   String
  subjectGroup    SubjectGroup
  averageScore    Decimal       @db.Decimal(5, 2)
  trend           PerformanceTrend
  consistency     Decimal       @db.Decimal(5, 2) // Taux de constance (0-100)
  gradesCount     Int           @default(0)
  minGrade        Decimal?      @db.Decimal(5, 2)
  maxGrade        Decimal?      @db.Decimal(5, 2)
  analysis        String?       @db.Text
  createdAt       DateTime      @default(now())

  orientation StudentOrientation @relation(fields: [orientationId], references: [id], onDelete: Cascade)

  @@unique([orientationId, subjectGroup])
  @@index([orientationId])
  @@map("subject_group_analyses")
}

enum SubjectGroup {
  LITTERAIRE        // Français, Philosophie, Langues
  SCIENTIFIQUE      // Maths, Physique-Chimie, SVT
  ECONOMIQUE        // Économie, Comptabilité, Gestion
  TECHNIQUE         // Technologie, Dessin technique
  LANGUES           // Anglais, Allemand, Espagnol
  ARTS              // Arts plastiques, Musique
  SPORT             // EPS
}

enum PerformanceTrend {
  STRONG_INCREASE   // Forte progression
  INCREASE          // Progression
  STABLE            // Stable
  DECREASE          // Régression
  STRONG_DECREASE   // Forte régression
}

// ============================================
// ANALYSE AVANCÉE DES APPRENANTS
// ============================================

model StudentAnalytics {
  id              String   @id @default(cuid())
  studentId       String
  periodId        String
  academicYearId  String

  // Moyennes
  generalAverage    Decimal?  @db.Decimal(5, 2)
  classRank         Int?
  classSize         Int?

  // Analyse de performance
  performanceLevel  PerformanceLevel?
  progressionRate   Decimal?  @db.Decimal(5, 2) // % progression vs période précédente
  consistencyRate   Decimal?  @db.Decimal(5, 2) // Taux de constance (écart-type normalisé)

  // Indicateurs de risque
  riskLevel         RiskLevel @default(NONE)
  riskFactors       String[]  @default([])

  // Métadonnées
  analyzedAt        DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  period       Period         @relation(fields: [periodId], references: [id], onDelete: Cascade)
  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  subjectPerformances SubjectPerformance[]

  @@unique([studentId, periodId])
  @@index([studentId])
  @@index([periodId])
  @@index([academicYearId])
  @@index([performanceLevel])
  @@index([riskLevel])
  @@map("student_analytics")
}

enum PerformanceLevel {
  EXCELLENT     // >= 16
  VERY_GOOD     // >= 14
  GOOD          // >= 12
  AVERAGE       // >= 10
  INSUFFICIENT  // >= 8
  WEAK          // < 8
}

enum RiskLevel {
  NONE          // Aucun risque
  LOW           // Risque faible
  MEDIUM        // Risque modéré
  HIGH          // Risque élevé
  CRITICAL      // Risque critique
}

model SubjectPerformance {
  id              String          @id @default(cuid())
  analyticsId     String
  subjectId       String

  // Statistiques
  average         Decimal?        @db.Decimal(5, 2)
  gradesCount     Int             @default(0)
  minGrade        Decimal?        @db.Decimal(5, 2)
  maxGrade        Decimal?        @db.Decimal(5, 2)
  standardDev     Decimal?        @db.Decimal(5, 2)

  // Analyse
  isStrength      Boolean         @default(false) // Point fort
  isWeakness      Boolean         @default(false) // Point faible
  trend           PerformanceTrend?
  progressionRate Decimal?        @db.Decimal(5, 2)

  createdAt       DateTime        @default(now())

  analytics StudentAnalytics @relation(fields: [analyticsId], references: [id], onDelete: Cascade)
  subject   Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([analyticsId, subjectId])
  @@index([analyticsId])
  @@index([subjectId])
  @@map("subject_performances")
}

// Historique des moyennes pour suivi de progression
model GradeHistory {
  id              String   @id @default(cuid())
  studentId       String
  subjectId       String?  // null = moyenne générale
  periodId        String
  academicYearId  String
  average         Decimal  @db.Decimal(5, 2)
  rank            Int?
  classSize       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject      Subject?       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  period       Period         @relation(fields: [periodId], references: [id], onDelete: Cascade)
  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId, periodId])
  @@index([studentId])
  @@index([subjectId])
  @@index([periodId])
  @@map("grade_history")
}

// ============================================
// DONNÉES DE RÉFÉRENCE DYNAMIQUES
// ============================================

model City {
  id          String   @id @default(cuid())
  name        String
  countryCode String   @default("BJ") // Code pays ISO (BJ = Bénin)
  region      String?  // Département/Région
  population  Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, countryCode])
  @@index([countryCode])
  @@index([region])
  @@map("cities")
}

model Profession {
  id          String   @id @default(cuid())
  name        String   @unique
  category    ProfessionCategory
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@map("professions")
}

enum ProfessionCategory {
  AGRICULTURE         // Agriculture, pêche, élevage
  ARTISANAT          // Artisans, métiers manuels
  COMMERCE           // Commerçants, vendeurs
  EDUCATION          // Enseignants, formateurs
  SANTE              // Médecins, infirmiers, pharmaciens
  FONCTION_PUBLIQUE  // Fonctionnaires, administration
  LIBERAL            // Professions libérales (avocat, architecte)
  TECHNIQUE          // Ingénieurs, techniciens
  SERVICE            // Services divers
  SANS_EMPLOI        // Sans emploi, retraité
  AUTRE              // Autres
}

model Nationality {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique // Code ISO 3166-1 alpha-3 (BEN, FRA, etc.)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([code])
  @@map("nationalities")
}

model SubjectCategory {
  id          String   @id @default(cuid())
  schoolId    String?  // null = catégorie globale
  name        String
  code        String
  description String?
  color       String?  // Pour UI (#FF5733)
  icon        String?  // Nom d'icône (lucide-react)
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, code])
  @@index([schoolId])
  @@map("subject_categories")
}

model ConfigOption {
  id          String   @id @default(cuid())
  schoolId    String?  // null = option globale
  category    String   // Ex: "RELATIONSHIP_TYPE", "ALLERGY_SEVERITY", etc.
  code        String
  label       String
  description String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  metadata    Json?    // Données additionnelles flexibles
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, category, code])
  @@index([schoolId, category])
  @@index([category])
  @@map("config_options")
}

// ============================================
// AUDIT / JOURNALISATION
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// IMPORT TEMPLATES
// ============================================

model ImportTemplate {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  type        ImportType
  mappings    Json     // Column mappings { sourceColumn: targetField }
  settings    Json?    // Additional settings (skipEmptyRows, etc.)
  isDefault   Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school    School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdBy User   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([schoolId, name, type])
  @@index([schoolId, type])
  @@map("import_templates")
}

enum ImportType {
  STUDENTS
  TEACHERS
  CLASSES
  PARENTS
  SUBJECTS
}

// ============================================
// COMMUNICATION HUB
// ============================================

model CommunicationPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  channels        String[] // ["EMAIL", "SMS", "WHATSAPP", "PUSH"]
  language        String   @default("fr") // "fr", "en", "fon", "yor"
  quietHoursStart String?  // "22:00"
  quietHoursEnd   String?  // "07:00"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("communication_preferences")
}

model CommunicationTemplate {
  id        String   @id @default(cuid())
  schoolId  String? // Nullable for system-wide templates
  name      String
  channel   String // "EMAIL", "SMS", "WHATSAPP"
  subject   String? // For email
  content   String // Text content with variables {{name}}
  language  String   @default("fr")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, channel, language])
  @@map("communication_templates")
}

model CommunicationLog {
  id        String   @id @default(cuid())
  schoolId  String
  userId    String? // Recipient if known user
  recipient String // Phone or Email
  channel   String
  type      String // TRANSACTIONAL, MARKETING, ALERT
  status    String // PENDING, SENT, FAILED, DELIVERED
  error     String?
  metadata  Json?
  createdAt DateTime @default(now())

  school School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([schoolId, createdAt])
  @@index([userId])
  @@map("communication_logs")
}

// ============================================
// GAMIFICATION
// ============================================

model Achievement {
  id          String   @id @default(cuid())
  code        String   @unique // STUDENT_OF_MONTH, PERFECT_ATTENDANCE
  name        String
  description String
  points      Int      @default(10)
  icon        String?  // URL or icon name
  criteria    Json?    // Logic for auto-awarding
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  progress      Int         @default(0) // For tracked achievements (e.g. 50/100 login)
  isUnlocked    Boolean     @default(true)

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model Leaderboard {
  id        String   @id @default(cuid())
  schoolId  String
  period    String   // "WEEKLY", "MONTHLY", "ALL_TIME"
  type      String   // "POINTS", "GRADES", "ATTENDANCE"
  userId    String
  score     Int
  rank      Int
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId, period, type, score(sort: Desc)])
  @@map("leaderboards")
}

// ============================================
// CANTEEN & NUTRITION
// ============================================

model CanteenMenu {
  id          String   @id @default(cuid())
  schoolId    String
  date        DateTime @db.Date
  dayOfWeek   String   // "MONDAY", "TUESDAY", etc.
  mealType    String   // "LUNCH", "SNACK"
  items       Json     // [{ name: "Riz Gras", allergens: ["Gluten"], price: 500 }]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, date])
  @@map("canteen_menus")
}

model MealTicket {
  id          String   @id @default(cuid())
  schoolId    String
  userId      String   // Student or Staff
  purchasedAt DateTime @default(now())
  validForDate DateTime? @db.Date
  status      String   // "VALID", "USED", "EXPIRED"
  qrCode      String   // "TICKET-12345"
  price       Decimal  @db.Decimal(10, 2)
  usedAt      DateTime?

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([qrCode])
  @@map("meal_tickets")
}

// ============================================
// LIBRARY
// ============================================

model Book {
  id          String   @id @default(cuid())
  schoolId    String
  isbn        String?
  title       String
  author      String
  category    String   // "TEXTBOOK", "NOVEL", "REFERENCE"
  quantity    Int      @default(1)
  available   Int      @default(1)
  location    String?  // "Shelf A3"
  coverImage  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school     School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  borrowings BorrowingRecord[]

  @@index([schoolId, title])
  @@map("books")
}

model BorrowingRecord {
  id         String    @id @default(cuid())
  bookId     String
  userId     String
  borrowedAt DateTime  @default(now())
  dueDate    DateTime
  returnedAt DateTime?
  status     String    // "BORROWED", "RETURNED", "OVERDUE"

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("borrowing_records")
}



