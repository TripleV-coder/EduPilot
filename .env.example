# ===========================================
# DATABASE
# ===========================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/edupilot?schema=public"

# ===========================================
# NEXTAUTH.JS
# ===========================================
# Generate a secure secret with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secure-secret-with-openssl-rand-base64-32"

# ===========================================
# APPLICATION
# ===========================================
NEXT_PUBLIC_APP_NAME="EduPilot"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===========================================
# EMAIL SERVICE (Optional - for password reset)
# ===========================================
# Supported providers: resend, sendgrid
# EMAIL_PROVIDER=resend
# EMAIL_API_KEY=re_xxxxxxxxxxxxx
# EMAIL_FROM=noreply@yourdomain.com
