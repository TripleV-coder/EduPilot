# ===========================================
# DATABASE
# ===========================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/edupilot?schema=public"

# ===========================================
# NEXTAUTH.JS
# ===========================================
# Generate a secure secret with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secure-secret-with-openssl-rand-base64-32"

# ===========================================
# APPLICATION
# ===========================================
NEXT_PUBLIC_APP_NAME="EduPilot"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===========================================
# EMAIL SERVICE (Optional - for password reset)
# ===========================================
# Supported providers: resend, sendgrid, smtp
# EMAIL_PROVIDER=smtp
# EMAIL_API_KEY="" # not needed for smtp
# EMAIL_FROM=noreply@yourdomain.com

# Configuration SMTP (Si EMAIL_PROVIDER="smtp")
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="votre_email@gmail.com"
# SMTP_PASS="votre_mot_de_passe_app"
# SMTP_SECURE="false" # true pour le port 465, false pour 587

# ===========================================
# SÉCURITÉ 2FA — CHIFFREMENT TOTP (REQUIS si 2FA activé)
# ===========================================
# Clé AES-256 pour chiffrer les secrets TOTP en base de données
# Générer avec : openssl rand -hex 32
TOTP_ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# ===========================================
# PAIEMENTS (requis pour les webhooks en production)
# ===========================================
# Clé secrète webhook Flutterwave (depuis le dashboard Flutterwave)
# FLUTTERWAVE_WEBHOOK_SECRET=your-flutterwave-webhook-secret
# Clé secrète Flutterwave pour les appels API
# FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxx
# Clé publique Flutterwave
# FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxx
# Clé secrète Paystack (si utilisé)
# PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx

# ===========================================
# CRON JOBS (requis si appel automatisé de /api/system/retention)
# ===========================================
# Secret partagé avec le scheduler pour les appels cron authentifiés
# Générer avec : openssl rand -hex 32
CRON_SECRET=generate-with-openssl-rand-hex-32

# ===========================================
# REDIS / RATE LIMITING (optionnel, recommandé en production)
# ===========================================
# UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ===========================================
# MONITORING (optionnel)
# ===========================================
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ===========================================
# ALERTES PERFORMANCE (optionnel)
# ===========================================
# Email pour recevoir les alertes performance (LCP, erreurs API, etc.)
# PERFORMANCE_ALERT_EMAIL=admin@yourdomain.com
# Webhook Slack pour notifications (format: https://hooks.slack.com/services/...)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
